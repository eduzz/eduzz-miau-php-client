{
    "name": "eduzz/miau-client",
    "description": "Eduzz Miau Client for PHP",
    "type": "library",
    "license": "MIT",
    "version": "1.4.2-rc.8",
    "require": {
        "php": ">=7.3",
        "ext-apcu": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "suggest": {
        "illuminate/http": "Required for the Laravel middleware (MiauMiddleware)"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Eduzz\\Miau\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eduzz\\Miau\\Tests\\": "tests/"
        }
    }
}
