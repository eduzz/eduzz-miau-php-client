{
    "name": "eduzz/miau-client",
    "description": "Eduzz Miau Client for PHP",
    "type": "library",
    "license": "MIT",
    "version": "1.4.2-rc.4",
    "require": {
        "php": ">=8.1",
        "ext-apcu": "*",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Eduzz\\Miau\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eduzz\\Miau\\Tests\\": "tests/"
        }
    }
}
